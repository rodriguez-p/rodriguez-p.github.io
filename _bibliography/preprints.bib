@article{rodriguez-san_esteban_rescuing_2026,
	title = {Rescuing unseen stimuli through alerting retro-cues},
	url = {https://www.biorxiv.org/content/10.64898/2026.03.13.711604v1},
	doi = {https://doi.org/10.64898/2026.03.13.711604},
	abstract= {Can we rescue a percept that would otherwise be processed non-consciously? While pre-stimulus alerting facilitates conscious access, the effects of retro-cues remain ambiguous due to methodological confounds. Specifically, most studies finding retro-cue benefits have relied on spatial features, confounding alerting with spatial selection. Our design addresses this by employing central visual targets and non-lateralized auditory cues, thereby isolating the temporal boost of phasic alerting from spatial orienting. Across four experiments, participants reported the presence and orientation of a central Gabor patch at near-threshold (~50% detection) or higher visibility (~75% detection). An auditory alerting tone was presented prior, simultaneously or after the Gabor at various stimulus onset asynchronies. Results consistently showed that pre-stimulus and simultaneous cues significantly enhanced conscious perception, increasing both seen rates and perceptual sensitivity.Crucially, retro-cue effectiveness strictly depended on stimulus visibility. While retro-cues provided no benefit under near-threshold conditions, an alerting cue presented 200 ms after target offset significantly increased the proportion of seen targets when visibility was higher. This suggests that a sufficiently robust sensory trace can be retrospectively rescued or promoted into awareness by a late alerting boost, and that pure alerting retro-cues can modulate conscious perception without spatial features.},
	language = {en},
	urldate = {},
	journal = {bioRxiv},
	author = {Rodríguez-San Esteban, Pablo and Mariagrazia Capizzi and José Andrés González-López and Ana B. Chica},
	month = mar,
	year = {2026},
	preprint = {https://www.biorxiv.org/content/10.64898/2026.03.13.711604v1},
}